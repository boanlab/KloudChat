    }
  },
  "3": {
    "class_type": "VAELoader",
    "_meta": {"title": "VAELoader"},
    "inputs": {
      "vae_name": "qwen-image-vae.safetensors"
    }
  },
  "4": {
    "class_type": "LoadImage",
    "_meta": {"title": "LoadImage"},
    "inputs": {
