#!/bin/bash
# CLI 도구 설정 — manage.sh / init.sh 가 사용
# 사용법:
#   1) cp scripts/config.env.example scripts/config.env
#   2) 필요 시 LITELLM_URL, DATA_DIR 수정
# (LITELLM_MASTER_KEY 는 .env 에서 자동 로드)

ENV_FILE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/.env"
if [[ -f "$ENV_FILE" ]]; then
  LITELLM_MASTER_KEY="$(grep -E '^LITELLM_MASTER_KEY=' "$ENV_FILE" | cut -d= -f2-)"
fi
export LITELLM_MASTER_KEY

export LITELLM_URL="http://localhost:8000"
export DATA_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.data"
