litellm_settings:
  # /app/callbacks/ 에 마운트된 CustomLogger 모듈들. 순서 무관.
  callbacks:
    # 로컬 모델이 OpenAI tool_calls 대신 텍스트로 함수 호출을 leak 하는 경우
    # (`<|python_tag|>{...}` / ```json 펜스 / 라벨 붙은 bare-JSON)를 tool_calls 로
    # 재구성하고, qwen 계열의 CJK 한자 leak 을 한글 음독으로 치환한다.
    - "callbacks.sanitize_python_tag.sanitizer_instance"
    # local/super-agent 호출 시 caller user_id 를 extra_body.user 로 주입 — shim 이
    # downstream end_user 태그로 propagate 해서 spend 가 default_user_id 가 아닌
    # 실제 호출자에 귀속되게 한다.
    - "callbacks.inject_super_agent_user.injector_instance"
    # local/* (qwen) 모델의 input 이 deployment 의 max_input_tokens 초과 시
    # graceful trim — librechat 의 summarization 이 꺼져 있어 (로컬 모델의 summary
    # 환각 회피) ctx 초과 시 hard fail 하던 걸 보완. ctx 는 model_info.max_input_tokens
    # 에서 동적 lookup. 모드는 KC_TRUNCATE_MODE 환경변수 (preserve_first 기본 — system
    # + 첫 user 턴 + 마지막 user 보호, 중간 oldest-first drop / drop_oldest — 마지막
    # user 만 보호). KC_TRUNCATE_SUMMARIZE=1 이면 drop 된 부분을 LLM 요약해 system 에
    # 합침 (opt-in). 자세한 정책은 truncate_to_ctx.py docstring.
    - "callbacks.truncate_to_ctx.truncator_instance"
    # qwen3.5:122b(Deep Research 두뇌)의 reasoning_content(장황한 "Thinking Process"
    # 사고 블록)를 제거 — content(최종 답)만 사용자에게. thinking 길이는 프롬프트로
    # 제어 불가라 표시 단계에서 숨긴다.
    - "callbacks.strip_reasoning.stripper_instance"
  drop_params: true
  drop_unsupported_params: true
  request_timeout: 900   # 15분 — Deep Research 122b 느린 호출 대비 (router timeout 과 동일)
  num_retries: 2
  check_provider_endpoint: false
  max_internal_user_budget: 25
  internal_user_budget_duration: "1mo"
  default_key_generate_params:
    max_budget: 10
    budget_duration: "1mo"
  upperbound_key_generate_params:
    max_budget: 9999
    tpm_limit: 100000
    rpm_limit: 500

anthropic_proxy:
  enabled: true
  prefix: /
