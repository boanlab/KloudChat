# ===== LibreChat =====
RAG_PORT=8000
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
CREDS_KEY=change-me-creds-key
CREDS_IV=change-me-creds-iv
MEILI_MASTER_KEY=change-me-meili-key

# ===== MongoDB =====
MONGO_ROOT_USER=kloudchat-librechat
MONGO_ROOT_PASSWORD=change-me-mongo-password

# ===== PostgreSQL (RAG) =====
POSTGRES_DB=kloudchat-ragdb
POSTGRES_USER=kloudchat-rag
POSTGRES_PASSWORD=change-me-rag-password

# ===== Ollama =====
OLLAMA_API_BASE=http://host.docker.internal:11434

# ===== RAG 임베딩 (Ollama) =====
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_MODEL=bge-m3

# ===== LiteLLM =====
LITELLM_DB_USER=kloudchat-litellm
LITELLM_DB_PASSWORD=change-me-litellm-db-password
LITELLM_MASTER_KEY=change-me-litellm-master-key
# init.sh 실행 후 자동 채워짐
LITELLM_SERVICE_KEY=

# ===== SearXNG =====
SEARXNG_INSTANCE_URL=http://searxng:8080

# ===== 코드 인터프리터 =====
CODE_INTERPRETER_API_KEY=change-me-code-interpreter-key
CODE_INTERPRETER_MINIO_USER=code-interpreter
CODE_INTERPRETER_MINIO_PASSWORD=change-me-minio-password
CODE_INTERPRETER_MINIO_BUCKET=code-interpreter
LIBRECHAT_CODE_BASEURL=http://code-interpreter:8000

# ===== STT (Whisper) =====
STT_PROVIDER=openAI
STT_BASE_URL=http://whisper:9000
STT_API_KEY=dummy
STT_MODEL=whisper-1

# ===== TTS (Kokoro) =====
TTS_PROVIDER=openAI
TTS_BASE_URL=http://kokoro:8880
TTS_API_KEY=dummy
TTS_MODEL=kokoro
TTS_VOICE=af_sky

# ===== 이미지 생성 (SD.Next — A1111 API 호환) =====
SD_WEBUI_URL=http://sdnext:7860
