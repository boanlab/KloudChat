# ━━━ 1. 사용자 입력 (필수 키 + 외부 연동) ━━━

# 브랜딩 (LibreChat UI 문구 — 빈 값이면 LibreChat 기본 문구 사용)
APP_TITLE=KloudChat
WELCOME_BACK_MESSAGE=KloudChat
HELP_AND_FAQ_URL=/
CUSTOM_FOOTER=KloudChat

# 모델 백엔드 토폴로지 (csv 로 멀티 노드)
#   OLLAMA  — LiteLLM router 가 모델별 least-busy LB
#   COMFYUI — comfyui-shim 이 alias 디스커버리 + VRAM-aware 라우팅
#   WHISPER — whisper-shim 이 /health + inflight + ollama VRAM 기준 라우팅
OLLAMA_URLS=http://host.docker.internal:11434
COMFYUI_URLS=http://host.docker.internal:8188
WHISPER_URLS=http://host.docker.internal:9000

# 외부 API 키 — OPENROUTER 또는 OLLAMA 모델 중 하나는 필수.
# Commercial 모델 (gpt-*/claude-*/gemini-*) 은 전부 OpenRouter 경유 (native API 직결 미지원).
OPENROUTER_API_KEY=

# HuggingFace gated repo (flux-dev 다운로드용; 없으면 flux-dev 제외)
HF_TOKEN=

# 회원가입 + 비밀번호 리셋 (LibreChat 가 /app/.env 직접 로드).
# 회원가입은 관리자만 (./scripts/manage.sh user create 로 생성) — false 권장.
# 비밀번호 리셋은 EMAIL_* 채워야 실제 발송. gmail 은 2FA + 앱 비밀번호 필요
# (https://support.google.com/accounts/answer/185833).
ALLOW_REGISTRATION=false
ALLOW_PASSWORD_RESET=true
EMAIL_SERVICE=gmail
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=KloudChat


# ━━━ 2. 서비스 자격증명 (gen-env.sh 가 change-me-* 를 랜덤 시크릿으로 치환) ━━━

# LibreChat 핵심 시크릿
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
CREDS_KEY=change-me-creds-key
CREDS_IV=change-me-creds-iv
MEILI_MASTER_KEY=change-me-meili-key

# MongoDB (대화 이력)
MONGO_ROOT_USER=kloudchat-librechat
MONGO_ROOT_PASSWORD=change-me-mongo-password

# PostgreSQL — RAG pgvector
POSTGRES_DB=kloudchat-ragdb
POSTGRES_USER=kloudchat-rag
POSTGRES_PASSWORD=change-me-rag-password

# LiteLLM 게이트웨이 + DB
LITELLM_DB_USER=kloudchat-litellm
LITELLM_DB_PASSWORD=change-me-litellm-db-password
LITELLM_MASTER_KEY=change-me-litellm-master-key

# Code Interpreter 샌드박스 + MinIO
CODE_INTERPRETER_API_KEY=change-me-code-interpreter-key
CODE_INTERPRETER_MINIO_USER=code-interpreter
CODE_INTERPRETER_MINIO_PASSWORD=change-me-minio-password
CODE_INTERPRETER_MINIO_BUCKET=code-interpreter


# ━━━ 3. setup.sh 가 런타임에 발급 (수동 편집 불필요) ━━━

LITELLM_SERVICE_KEY=
RAG_OPENAI_API_KEY=


# ━━━ 4. 내부 endpoint (보통 기본값 유지) ━━━

RAG_PORT=8000
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=bge-m3
RAG_OPENAI_BASEURL=http://litellm:8000/v1
SEARXNG_INSTANCE_URL=http://searxng:8080
LIBRECHAT_CODE_BASEURL=http://code-interpreter:8000
SD_WEBUI_URL=http://comfyui-shim:7860
WHISPER_URL=http://whisper-shim:9000
WHISPER_OR_MODEL=whisper-1
