# KloudChat environment configuration.
# Generate a working .env with random secrets:  ./scripts/gen-env.sh
# Reference table:  docs/env-reference.md

# ===== LibreChat =====
RAG_PORT=8000
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
CREDS_KEY=change-me-creds-key
CREDS_IV=change-me-creds-iv
MEILI_MASTER_KEY=change-me-meili-key

# ===== MongoDB =====
MONGO_ROOT_USER=kloudchat-librechat
MONGO_ROOT_PASSWORD=change-me-mongo-password

# ===== PostgreSQL (RAG / pgvector) =====
POSTGRES_DB=kloudchat-ragdb
POSTGRES_USER=kloudchat-rag
POSTGRES_PASSWORD=change-me-rag-password

# ===== Ollama (host-installed, not containerised) =====
# Docker containers reach the host through host.docker.internal.
# install-ollama.sh sets OLLAMA_HOST=0.0.0.0:11434 on the host.
OLLAMA_API_BASE=http://host.docker.internal:11434

# ===== RAG embeddings (Ollama) =====
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_MODEL=bge-m3

# ===== LiteLLM =====
LITELLM_DB_USER=kloudchat-litellm
LITELLM_DB_PASSWORD=change-me-litellm-db-password
LITELLM_MASTER_KEY=change-me-litellm-master-key
# Populated automatically by ./scripts/init.sh
LITELLM_SERVICE_KEY=

# ===== SearXNG =====
SEARXNG_INSTANCE_URL=http://searxng:8080

# ===== Code interpreter =====
CODE_INTERPRETER_API_KEY=change-me-code-interpreter-key
CODE_INTERPRETER_MINIO_USER=code-interpreter
CODE_INTERPRETER_MINIO_PASSWORD=change-me-minio-password
CODE_INTERPRETER_MINIO_BUCKET=code-interpreter
LIBRECHAT_CODE_BASEURL=http://code-interpreter:8000

# ===== STT — Whisper (Linux + amd64 + NVIDIA GPU only) =====
# Container is omitted automatically on macOS / arm64 / non-GPU hosts.
STT_PROVIDER=openAI
STT_BASE_URL=http://whisper:9000
STT_API_KEY=dummy
STT_MODEL=whisper-1

# ===== TTS — openedai-speech (piper + xtts_v2, multi-arch + CPU) =====
# The actual endpoint / model / voice is wired through librechat.yaml's
# speech.tts section. Values below are documentation-only because LibreChat
# prefers librechat.yaml over .env for speech config.
TTS_PROVIDER=openAI
TTS_BASE_URL=http://tts:8000
TTS_API_KEY=dummy
TTS_MODEL=tts-1-hd
TTS_VOICE=korean

# ===== Image generation — ComfyUI via A1111-compatible shim =====
# LibreChat's built-in stable-diffusion tool speaks A1111, so we point it at
# comfyui-shim. The shim translates /sdapi/v1/{txt2img,img2img} into ComfyUI
# workflows for SDXL, Qwen-Image, and Qwen-Image-Edit.
# Requires Linux + NVIDIA GPU (amd64 or arm64); auto-skipped otherwise.
SD_WEBUI_URL=http://comfyui-shim:7860
