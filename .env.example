# ━━━ 1. 사용자 입력 ━━━

# UI 브랜딩 (빈 값 = 기본 문구).
APP_TITLE=KloudChat
WELCOME_BACK_MESSAGE=KloudChat
HELP_AND_FAQ_URL=/
CUSTOM_FOOTER=KloudChat

# 공개 base URL — 이메일 링크/OAuth 콜백/이미지 path. 실배포 도메인 필수.
DOMAIN_CLIENT=http://localhost:8080
DOMAIN_SERVER=http://localhost:8080

# 관리자 계정 정보. setup.sh (librechat 단계) 가 이 값으로 LibreChat ADMIN 계정을
# 자동 생성한다. ADMIN_PW 는 change-me- 라 gen-env.sh 가 랜덤값으로 교체한다.
ADMIN_ID=admin
ADMIN_PW=change-me-admin-pw
ADMIN_EMAIL=admin@example.com

# 비밀번호 리셋 = EMAIL_* 필요. Gmail 은 2FA + app password.
ALLOW_REGISTRATION=false
ALLOW_PASSWORD_RESET=true
EMAIL_SERVICE=gmail
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=KloudChat

# LiteLLM endpoint — librechat/rag 등 *내부 서비스*가 LiteLLM 을 직접 부르는 주소.
# 컨테이너에서 localhost 는 자기 자신이고 litellm 은 별도 compose 스택(다른 도커 네트워크)
# 이라 service 이름으로도 못 닿는다 → host gateway 로 직결. 외부 프록시 URL(예:
# https://api.example.com)을 넣으면 내부 호출이 프록시를 빙 돌아 긴 요청에서 504 가 난다.
# 다른 노드면 http://<litellm-host>:8000.
LITELLM_URL=http://host.docker.internal:8000

# OpenRouter (commercial 모델) 또는 로컬 vLLM 백엔드 ≥1 필수.
OPENROUTER_API_KEY=

# HuggingFace gated repo (flux-dev, Qwen FP8 변종 등).
HF_TOKEN=

# ssh 타겟 (멀티노드) — user@host (또는 ssh config alias). NODES_* csv = host-install,
# NODE_* 단일 = stack. 비우면 해당 role 건너뜀. 예: NODES_VLLM=ops@gpu-1,ops@gpu-2
NODES_VLLM=
NODES_COMFYUI=
NODES_WHISPER=
NODE_LITELLM=
NODE_LIBRECHAT=


# ━━━ 2. 시크릿 (gen-env.sh 가 change-me-* 를 랜덤으로 치환) ━━━

JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
CREDS_KEY=change-me-creds-key
CREDS_IV=change-me-creds-iv
MEILI_MASTER_KEY=change-me-meili-key
SEARXNG_SECRET_KEY=change-me-searxng-secret

MONGO_ROOT_USER=kloudchat-librechat
MONGO_ROOT_PASSWORD=change-me-mongo-password

POSTGRES_DB=kloudchat-ragdb
POSTGRES_USER=kloudchat-rag
POSTGRES_PASSWORD=change-me-rag-password

LITELLM_DB_USER=kloudchat-litellm
LITELLM_DB_PASSWORD=change-me-litellm-db-password
LITELLM_MASTER_KEY=change-me-litellm-master-key
LITELLM_NUM_WORKERS=4

CODE_INTERPRETER_API_KEY=change-me-code-interpreter-key
CODE_INTERPRETER_MINIO_USER=code-interpreter
CODE_INTERPRETER_MINIO_PASSWORD=change-me-minio-password
CODE_INTERPRETER_MINIO_BUCKET=code-interpreter


# ━━━ 3. setup.sh 가 런타임에 발급 ━━━

LITELLM_SERVICE_KEY=
RAG_OPENAI_API_KEY=


# ━━━ 4. 내부 endpoint (기본값 유지) ━━━

RAG_PORT=8000
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=bge-m3
SEARXNG_INSTANCE_URL=http://searxng:8080
LIBRECHAT_CODE_BASEURL=http://code-interpreter:8000
# SD_WEBUI_URL: LibreChat 내장 이미지(SD) 도구가 읽는 변수명 — 실제 백엔드는 comfyui-shim(A1111 호환).
SD_WEBUI_URL=http://comfyui-shim:7860
WHISPER_URL=http://whisper-shim:9000
# 웹 검색/스크레이핑 — firecrawl 프로토콜 shim 뒤의 self-hosted Crawl4AI (shim 무인증).
FIRECRAWL_BASE_URL=http://crawl4ai-shim:8080
FIRECRAWL_API_KEY=internal-shim-noauth
# whisper-shim STT — 무인증이라 빈 값(Authorization 미전송). librechat.yaml 스키마 필수 필드 충족용.
WHISPER_STT_API_KEY=


# ━━━ 5. 모델 backend URL — scheduler 자동 지정 (단일노드 fallback) ━━━
# 멀티노드는 §1 의 NODES_* 만 채우면 setup.sh all 이 자동 갱신
# (Whisper=derive, vLLM/ComfyUI=scheduler). 단일노드는 아래 fallback 사용.
# shim 컨테이너 안에서 호스트의 ComfyUI/whisper 에 닿아야 하므로 host.docker.internal
# (또는 호스트 IP) 사용 — localhost 는 컨테이너 자기 자신이라 안 됨.
COMFYUI_URLS=http://host.docker.internal:8188
WHISPER_URLS=http://host.docker.internal:9000

# vLLM chat URL. 비우면 단일노드 fallback 으로 scheduler 가 채운다. 멀티노드는 §1 의
# NODES_VLLM.
VLLM_GEMMA26_URL=
VLLM_BGE_M3_URL=

# smart_search Phase 2 reranker (bge-reranker-v2-m3) 의 /rerank endpoint. 비우면
# rerank 스킵(hybrid 까지). 배포 절차는 docs/smart-search.md.
RERANK_URL=

# KloudChat 자체 이미지 네임스페이스 + 태그 (boanlab/kloudchat-* 형태).
# compose 는 이 값으로 이미지를 pull 하고, scripts/build-push-images.sh 는 같은 값으로
# build·push 한다. 다른 레지스트리/조직으로 publish 하려면 NS 를 바꾼다 (예: ghcr.io/your-org).
KLOUDCHAT_IMAGE_NS=boanlab
KLOUDCHAT_IMAGE_TAG=latest

# vLLM chat launch 옵션. *_MAX_LEN = vLLM --max-model-len + LiteLLM
# max_input_tokens 폴백. 노드별 다른 값은 scheduler 가 노드 .env 에 직접 박음.
# VLLM_IMAGE: amd64 (RTX4090/RTX5090/PRO5000/PRO6000) 는 표준 amd64 vLLM 이미지를
# 명시한다. 비우면 compose default 의 arm64 (GB10) 용 `*-aarch64` 이미지를 쓴다.
VLLM_IMAGE=
VLLM_MODELS_ROOT=/var/lib/vllm/models
# chat + artifact + image-brain 통합 (gemma-4-26b, NVFP4; RTX4090 은 AWQ-int4). port 8001.
VLLM_GEMMA26_DIR=gemma-4-26b
VLLM_GEMMA26_GPU_UTIL=0.45
VLLM_GEMMA26_MAX_LEN=16384
VLLM_GEMMA26_MAX_BATCHED_TOKENS=16384
VLLM_BGE_M3_GPU_UTIL=0.05

# vLLM Deep Research / Slide Studio (옵셔널) — Qwen3.5-122B-A10B (NVFP4). 노드 격리.
# port 8002, `manage-vllm.sh up --deep`.
VLLM_QWEN122B_URL=
VLLM_QWEN122B_DIR=qwen3.5-122b-a10b
VLLM_QWEN122B_GPU_UTIL=0.90
VLLM_QWEN122B_MAX_LEN=131072
VLLM_QWEN122B_MAX_BATCHED_TOKENS=16384

# vLLM coder (옵셔널) — coding assist 전용 (litellm-등록, LibreChat UI/agent 숨김).
# 외부 코딩 클라이언트 (Claude Code / Codex) 용. 노드 격리 (~80GB). port 8003,
# `manage-vllm.sh up --coder`.
VLLM_CODERNEXT_URL=
VLLM_CODERNEXT_DIR=qwen3-coder-next
VLLM_CODERNEXT_GPU_UTIL=0.80
VLLM_CODERNEXT_MAX_LEN=32768
