FROM registry.librechat.ai/danny-avila/librechat:v0.8.5

# 1. streamAudio.js TTS thinking 필터 patch
# Qwen 등 reasoning 모델이 thinking 토큰을 발화하지 않도록 parseTextParts 의 두 번째 인자 true.
RUN sed -i 's|parseTextParts(message.content)|parseTextParts(message.content, true)|g' \
    /app/api/server/services/Files/Audio/streamAudio.js && \
    grep -q 'parseTextParts(message.content, true)' /app/api/server/services/Files/Audio/streamAudio.js \
    || (echo "ERROR: streamAudio.js TTS thinking patch failed" && exit 1)

# 2. Client bundle — .hwp 파일 업로드 검증 통과 patch
# 브라우저가 .hwp MIME 모르면 file.type="" → inferMimeType()="" → "Unable to determine file type" 에러.
# inferMimeType 호출 직전 e.type 을 .hwp/.hwpx 면 application/x-hwp 로 강제 지정.
# rag_api 의 .hwp 분기 (Dockerfile.rag) 와 짝.
RUN F=$(ls /app/client/dist/assets/index.*.js 2>/dev/null | head -1) && \
    [ -n "$F" ] && \
    sed -i 's|(e\.name,e\.type);if(!a)return n("Unable to determine|(e.name,/\\.hwpx?$/i.test(e.name)?"application/x-hwp":e.type);if(!a)return n("Unable to determine|g' "$F" && \
    grep -q 'hwpx?\$/i.test(e.name)' "$F" \
    || (echo "ERROR: client bundle .hwp patch failed (base image bundle pattern changed?)" && exit 1)

# patch 후 bundle hash 변경 — 브라우저가 같은 URL 의 옛 캐시 안 쓰도록 강제 fresh fetch.
# 같은 hash 그대로 두면 immutable cache 정책으로 브라우저가 패치 못 받음.
RUN F=$(ls /app/client/dist/assets/index.*.js 2>/dev/null | head -1) && \
    OLD=$(basename "$F") && \
    NEW="index.kc$(sha1sum "$F" | cut -c1-8).js" && \
    mv "$F" "$(dirname "$F")/$NEW" && \
    sed -i "s|$OLD|$NEW|g" /app/client/dist/index.html && \
    grep -q "$NEW" /app/client/dist/index.html \
    || (echo "ERROR: bundle rename / index.html update failed" && exit 1)

# 3. PWA Service Worker 비활성화
# vite-plugin-pwa 가 bundle 을 hash 기준 byte-level 캐시 → 우리가 in-place patch 한
# bundle 을 service worker 가 옛 캐시본으로 덮어 사용자 브라우저에 patch 안 반영됨.
# registerSW.js 를 빈 파일로 만들어 SW 등록 자체 차단. 데모/운영엔 PWA 불필요.
# 부작용: 오프라인 사용 / "홈 화면에 추가" 기능 미동작 (LibreChat 핵심 기능과 무관)
RUN echo '' > /app/client/dist/registerSW.js && \
    grep -l 'Service-Worker\|serviceWorker' /app/client/dist/sw.js >/dev/null 2>&1 && \
    echo '' > /app/client/dist/sw.js || true
